{
  "version": 2,
  "regions": ["sin1"],
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": { "maxDuration": 300 }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/(.*\\.[a-zA-Z0-9]+)$", "dest": "/client/$1" },
    { "src": "/(.*)", "dest": "/client/index.html" }
  ]
}
