# ─────────────────────────────────────────────────────────────────────
# BOM System — .env template
# Copy to `.env` and fill in real values. Never commit a real .env.
# ─────────────────────────────────────────────────────────────────────

# ── PostgreSQL (required) ───────────────────────────────────────────
# Two ways to configure the connection — pick ONE:
#
# (A) Preferred on hosted platforms (Neon / Render / Railway): a single
#     connection string. Copy it from Neon's dashboard. This is a
#     SERVER-SIDE SECRET — it belongs only in the backend host's env,
#     never in the frontend / Vercel / any VITE_ variable.
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
#
# (B) Discrete fields (original local form). Used only when DATABASE_URL
#     is not set.
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# ── Odoo v18 (required for both product sync AND real user login) ──
# ODOO_URL: base URL of the Odoo instance, e.g. https://my-co.odoo.com
# ODOO_DB:  Odoo database name (visible in the Odoo /web URL)
# ODOO_USER / ODOO_PASSWORD: SERVICE account used by the background
#   product sync only. End-user logins use whatever each user types
#   on the login screen, not these credentials.
ODOO_URL=https://your-instance.odoo.com
ODOO_DB=your-odoo-db-name
ODOO_USER=service-account@example.com
ODOO_PASSWORD=

# ── Multi-company scope (which company's products to sync) ─────────
# The Odoo instance hosts several companies (one per location). The
# product sync pulls ONLY raw materials belonging to the company below
# (plus company-shared products). Set EITHER:
#   ODOO_COMPANY_NAME — matched against res.company by name (default
#                       "The Kosher Place (Thailand) Co. Ltd"), or
#   ODOO_COMPANY_ID   — the exact res.company id (skips the name lookup;
#                       wins over ODOO_COMPANY_NAME when set).
ODOO_COMPANY_NAME=The Kosher Place (Thailand) Co. Ltd
# ODOO_COMPANY_ID=

# ── App ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT (required — issued after successful login) ──────────────────
# Generate a long random value, e.g. `openssl rand -hex 48`
JWT_SECRET=
JWT_EXPIRES_IN=8h

# ── DEV-ONLY LOCAL ADMIN BYPASS (optional, off by default) ──────────
# Set ALLOW_DEV_LOGIN=true to enable a single hardcoded-from-env
# admin login that does NOT call Odoo. Useful while Odoo creds are
# being set up. MUST be unset / set to 'false' in production.
# Server prints a loud warning at boot whenever this is active.
ALLOW_DEV_LOGIN=false
DEV_ADMIN_USER=admin
DEV_ADMIN_PASSWORD=

# ── Sync schedule (cron syntax, default: every 6 hours) ─────────────
ODOO_SYNC_SCHEDULE=0 */6 * * *
